{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiNuggets": {
    "Jwt": {
      "Enable": true,
      "Key": "super_secret_key_that_is_long_enough_123!",
      "Issuer": "ApiNuggets",
      "Audience": "ApiNuggets",
      "ExpiryMinutes": 60
    },
    "RateLimiting": {
      "Enable": true,
      "RequestsPerMinute": 60
    },
    "Analytics": {
      "Enable": true,
      "SlowRequestThresholdMs": 500,
      "MaxLogEntries": 1000
    },
    "ResponseWrapper": {
      "Enable": true
    },
    "Dashboard": {
      "Path": "/api-nuggets/dashboard",
      "EnableUi": true,
      "RequireAuthentication": false
    },
    "Versioning": {
      "Enable": true,
      "DefaultVersion": "1.0"
    }
  }
}
